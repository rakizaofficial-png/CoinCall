# =============================================================================
# COINCALL API — copy to server/.env / set on Render (coincall-api)
# NEVER commit real secrets.
# =============================================================================
#
# Shared live stack (User + Host):
#   • API  = wallets, calls, DMs, presence, host profile metadata
#   • MongoDB Atlas (MONGODB_URI) = durable cloud DB across Render deploys
#   • Firebase Storage = host DPs / intro videos (https URLs only in DB)
#   • Firebase Auth + RTDB = host login / profile mirror
#   • Disk (.data or DATA_DIR) = always-on fallback if Mongo is down
#
# =============================================================================

PORT=4000
ADMIN_API_KEY=change-me-admin-key

AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# ---- Cloud database (REQUIRED for durable wallets/profiles) ----
MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=coincall
# Alternate (only if it starts with mongodb):
# DATABASE_URL=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/

# Optional Render persistent disk
# DATA_DIR=/var/data

# Absolute public API URL (avatar / media links)
API_PUBLIC_URL=https://coincall-api.onrender.com
PUBLIC_API_URL=https://coincall-api.onrender.com

AI_HOST_CDN=

EASYPAY_MERCHANT_ID=
EASYPAY_STORE_ID=
EASYPAY_HASH_KEY=
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
BANK_PAYOUT_WEBHOOK_SECRET=

GOOGLE_PLAY_PACKAGE_NAME=com.yourcompany.luma
GOOGLE_PLAY_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
APPLE_IAP_SHARED_SECRET=
APPLE_IAP_BUNDLE_ID=com.yourcompany.luma

# ALLOW_IAP_STUB=1
# ALLOW_FREE_VIP=1
REDIS_URL=
