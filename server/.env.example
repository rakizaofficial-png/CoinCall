# =============================================================================
# COINCALL API — copy to server/.env (NEVER commit real secrets)
# =============================================================================
#
# SETUP CHECKLIST:
# 1. Agora: https://console.agora.io → App ID + Primary Certificate
# 2. EasyPaisa / JazzCash merchant credentials from your bank dashboard
# 3. Google Play: service account JSON for purchase token verification
# 4. Apple: App Store Connect shared secret / App Store Server API keys
# 5. Optional: DATABASE_URL when you move off in-memory Maps to Postgres
#
# =============================================================================

PORT=4000
ADMIN_API_KEY=change-me-admin-key

AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# Public CDN for AI fallback clips
AI_HOST_CDN=

# Withdrawal gateways (host cash-out)
EASYPAY_MERCHANT_ID=
EASYPAY_STORE_ID=
EASYPAY_HASH_KEY=
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
BANK_PAYOUT_WEBHOOK_SECRET=

# IAP verification
GOOGLE_PLAY_PACKAGE_NAME=com.yourcompany.luma
GOOGLE_PLAY_SERVICE_ACCOUNT_EMAIL=
# Path or raw JSON for Google Play Developer API
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
APPLE_IAP_SHARED_SECRET=
APPLE_IAP_BUNDLE_ID=com.yourcompany.luma

# Optional persistence
DATABASE_URL=
REDIS_URL=
