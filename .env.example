# CoinCall host client (Expo) — copy to `.env`
# Secrets stay on the API server only.

EXPO_PUBLIC_APP_ENV=production
EXPO_PUBLIC_API_BASE_URL=https://coincall-api.onrender.com/api

# Filled automatically by `npx eas init` (also written into app.config.ts extra.eas.projectId)
EXPO_PUBLIC_EAS_PROJECT_ID=

# Agora Console App ID (certificate is SERVER-ONLY)
EXPO_PUBLIC_AGORA_APP_ID=

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_VAPID_KEY=
EXPO_PUBLIC_FIREBASE_DATABASE_URL=

EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
