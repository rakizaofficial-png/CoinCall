# Copy this file to `.env` and fill in real values.
# Never commit `.env` or share secret keys in chat screenshots.

# ─── App ───────────────────────────────────────────────
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_API_BASE_URL=https://YOUR_API_DOMAIN.com/api

# ─── Firebase (Auth + Firestore + FCM) ─────────────────
# Firebase Console → Project settings → Your apps → Web app
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
# Optional web push (FCM)
EXPO_PUBLIC_FIREBASE_VAPID_KEY=
# After creating Realtime Database, paste the database URL here:
EXPO_PUBLIC_FIREBASE_DATABASE_URL=

# ─── Agora (1:1 video) ─────────────────────────────────
# Agora Console → Project → App ID + Primary Certificate
EXPO_PUBLIC_AGORA_APP_ID=
# NEVER put Agora App Certificate in the mobile app.
# Token must be minted by your backend:
# AGORA_APP_CERTIFICATE=   (backend/.env only)

# ─── Stripe (coin purchases) ───────────────────────────
# Stripe Dashboard → Developers → API keys
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Secret key belongs on backend ONLY:
# STRIPE_SECRET_KEY=sk_test_...

# ─── Optional: Pakistan wallets later ──────────────────
# JAZZCASH_MERCHANT_ID=
# EASYPAISA_STORE_ID=
