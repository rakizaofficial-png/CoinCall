{
  "name": "coincall",
  "license": "0BSD",
  "main": "index.ts",
  "dependencies": {
    "@expo/metro-runtime": "^57.0.6",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.18.11",
    "@react-navigation/native": "^7.3.11",
    "@react-navigation/native-stack": "^7.18.3",
    "agora-extension-beauty-effect": "^1.0.2-beta",
    "agora-rtc-sdk-ng": "^4.24.6",
    "agora-rte-extension": "^1.2.4",
    "babel-preset-expo": "^57.0.3",
    "expo": "~57.0.7",
    "expo-blur": "~57.0.2",
    "expo-build-properties": "^57.0.6",
    "expo-camera": "^57.0.3",
    "expo-clipboard": "^57.0.1",
    "expo-constants": "~57.0.6",
    "expo-dev-client": "^57.0.7",
    "expo-device": "^57.0.1",
    "expo-font": "~57.0.1",
    "expo-image-picker": "~57.0.5",
    "expo-linear-gradient": "^57.0.1",
    "expo-linking": "~57.0.0",
    "expo-notifications": "^57.0.6",
    "expo-secure-store": "^57.0.1",
    "expo-status-bar": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "expo-video": "~57.0.1",
    "firebase": "^12.16.0",
    "lucide-react-native": "^1.25.0",
    "react": "19.2.3",
    "react-dom": "^19.2.3",
    "react-native": "0.86.0",
    "react-native-agora": "^4.6.2",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.10.0"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.2.2",
    "typescript": "^5.9.2"
  },
  "expo": {
    "install": {
      "exclude": [
        "typescript"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false
      }
    }
  },
  "scripts": {
    "start": "__UNSAFE_EXPO_HOME_DIRECTORY=$PWD/.expo-home expo start",
    "android": "__UNSAFE_EXPO_HOME_DIRECTORY=$PWD/.expo-home expo start --android",
    "ios": "__UNSAFE_EXPO_HOME_DIRECTORY=$PWD/.expo-home expo start --ios",
    "web": "__UNSAFE_EXPO_HOME_DIRECTORY=$PWD/.expo-home expo start --web",
    "export:web": "EXPO_PUBLIC_APP_ENV=production npx expo export --platform web",
    "eas:login": "npx eas-cli@latest login",
    "eas:init": "npx eas-cli@latest init",
    "build:android": "npx eas-cli@latest build --platform android --profile production",
    "build:ios": "npx eas-cli@latest build --platform ios --profile production",
    "build:store": "npx eas-cli@latest build --platform all --profile production",
    "build:dev:android": "npx eas-cli@latest build --platform android --profile development",
    "build:dev:ios": "npx eas-cli@latest build --platform ios --profile development",
    "build:preview:android": "npx eas-cli@latest build --platform android --profile preview",
    "server": "npm --prefix server run dev",
    "admin": "npm --prefix admin run dev",
    "smoke": "node scripts/smoke-production.mjs",
    "build:all": "npm --prefix luma-user run build && npm run export:web && npm --prefix admin run build"
  },
  "packageManager": "npm@10.8.2"
}
